{
  "name": "editar agendamento",
  "startUrl": "https://cliente.exemplo.com.br/painel-admin",
  "environment": "hml",
  "steps": [
    {
      "order": 1,
      "action": "type",
      "target": {
        "strategy": "css",
        "selector": "[name='usuario']",
        "recommendedCommand": "get"
      },
      "value": "{{usuario}}",
      "variableName": "usuario",
      "selectorQuality": "medium"
    },
    {
      "order": 2,
      "action": "type",
      "target": {
        "strategy": "css",
        "selector": "[name='password']",
        "recommendedCommand": "get"
      },
      "value": "{{password}}",
      "variableName": "password",
      "selectorQuality": "medium"
    },
    {
      "order": 3,
      "action": "click",
      "target": {
        "strategy": "text",
        "selector": "button",
        "text": "Entrar",
        "recommendedCommand": "contains"
      },
      "selectorQuality": "medium"
    },
    {
      "order": 4,
      "action": "click",
      "target": {
        "strategy": "text",
        "selector": "a",
        "text": "Agendamentos",
        "recommendedCommand": "contains"
      },
      "selectorQuality": "medium"
    },
    {
      "order": 5,
      "action": "click",
      "target": {
        "strategy": "text",
        "selector": "tr",
        "text": "{{pacienteNome}}",
        "recommendedCommand": "contains"
      },
      "value": "{{pacienteNome}}",
      "variableName": "pacienteNome",
      "selectorQuality": "medium"
    },
    {
      "order": 6,
      "action": "click",
      "target": {
        "strategy": "text",
        "selector": "button",
        "text": "Editar",
        "recommendedCommand": "contains"
      },
      "selectorQuality": "medium"
    },
    {
      "order": 7,
      "action": "type",
      "target": {
        "strategy": "css",
        "selector": "[name='horarioAgendamento']",
        "recommendedCommand": "get"
      },
      "value": "{{novoHorario}}",
      "variableName": "novoHorario",
      "selectorQuality": "strong"
    },
    {
      "order": 8,
      "action": "click",
      "target": {
        "strategy": "text",
        "selector": "button",
        "text": "Salvar alteracoes",
        "recommendedCommand": "contains"
      },
      "selectorQuality": "medium"
    },
    {
      "order": 9,
      "action": "assertVisible",
      "target": {
        "strategy": "text",
        "selector": "body",
        "text": "Agendamento atualizado com sucesso",
        "recommendedCommand": "contains"
      },
      "selectorQuality": "medium"
    }
  ]
}
